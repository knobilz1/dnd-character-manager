{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Tavern Sheet",
  "version": "0.22.11",
  "identifier": "com.nabil.dndsheet",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Tavern Sheet",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$RESOURCE/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "knobilz1",
    "resources": {
      "../public/models/*_Idle.glb": "models/",
      "../public/models/*_Anims.glb": "models/",
      "../public/models/*.png": "models/",
      "../public/models/armor/*.glb": "models/armor/",
      "../public/models/hair/*.glb": "models/hair/"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhGODZERDg4QTI4QkNCODgKUldTSXk0dWlpTjJHajJtMm9KQ1ZDUG1NVTRhOUV1cXQxWDN1TGErbGpDa0pNTGtXaFpZUUd5MWwK",
      "endpoints": [
        "https://github.com/knobilz1/dnd-character-manager/releases/latest/download/latest.json"
      ]
    }
  }
}
